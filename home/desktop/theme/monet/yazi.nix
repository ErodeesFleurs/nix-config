{ config, themeLib }:

let
  enabled = config.programs.yazi.enable;
in
themeLib.mkApp {
  enable = enabled;
  outputDirs = [ "$out/yazi" ];

  generate =
    { polarity }:
    ''
      jq -r '
        def c($name): .colors[$name]["${polarity}"].color;
        [
          "# Generated by matugen using Material Design 3 color roles",
          "",
          "[mgr.cwd]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[mgr.hovered]",
          "fg = \"" + c("on_primary_container") + "\"",
          "bg = \"" + c("primary_container") + "\"",
          "bold = true",
          "",
          "[mgr.preview_hovered]",
          "underline = true",
          "",
          "[mgr.find_keyword]",
          "fg = \"" + c("primary") + "\"",
          "bold = true",
          "",
          "[mgr.find_position]",
          "fg = \"" + c("on_tertiary_container") + "\"",
          "bg = \"" + c("tertiary_container") + "\"",
          "",
          "[mgr.marker_copied]",
          "fg = \"" + c("secondary") + "\"",
          "",
          "[mgr.marker_cut]",
          "fg = \"" + c("error") + "\"",
          "",
          "[mgr.marker_selected]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[mgr.border_style]",
          "fg = \"" + c("outline_variant") + "\"",
          "",
          "[tabs.active]",
          "fg = \"" + c("on_primary_container") + "\"",
          "bg = \"" + c("primary_container") + "\"",
          "bold = true",
          "",
          "[tabs.inactive]",
          "fg = \"" + c("on_surface_variant") + "\"",
          "bg = \"" + c("surface_container") + "\"",
          "",
          "[status]",
          "separator_open = \"\"",
          "separator_close = \"\"",
          "",
          "[status.mode_normal]",
          "fg = \"" + c("on_primary") + "\"",
          "bg = \"" + c("primary") + "\"",
          "bold = true",
          "",
          "[status.mode_select]",
          "fg = \"" + c("on_tertiary_container") + "\"",
          "bg = \"" + c("tertiary_container") + "\"",
          "bold = true",
          "",
          "[status.mode_unset]",
          "fg = \"" + c("on_error_container") + "\"",
          "bg = \"" + c("error_container") + "\"",
          "bold = true",
          "",
          "[status.progress_label]",
          "fg = \"" + c("primary") + "\"",
          "bold = true",
          "",
          "[status.progress_normal]",
          "fg = \"" + c("primary") + "\"",
          "bg = \"" + c("surface_container_high") + "\"",
          "",
          "[status.progress_error]",
          "fg = \"" + c("error") + "\"",
          "bg = \"" + c("surface_container_high") + "\"",
          "",
          "[input.border]",
          "fg = \"" + c("outline_variant") + "\"",
          "",
          "[input.title]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[input.value]",
          "fg = \"" + c("on_surface") + "\"",
          "",
          "[input.selected]",
          "fg = \"" + c("on_primary_container") + "\"",
          "bg = \"" + c("primary_container") + "\"",
          "",
          "[select.border]",
          "fg = \"" + c("outline_variant") + "\"",
          "",
          "[select.active]",
          "fg = \"" + c("on_primary_container") + "\"",
          "bg = \"" + c("primary_container") + "\"",
          "",
          "[select.inactive]",
          "fg = \"" + c("on_surface_variant") + "\"",
          "",
          "[completion.border]",
          "fg = \"" + c("outline_variant") + "\"",
          "",
          "[completion.active]",
          "fg = \"" + c("on_primary_container") + "\"",
          "bg = \"" + c("primary_container") + "\"",
          "",
          "[completion.inactive]",
          "fg = \"" + c("on_surface_variant") + "\"",
          "",
          "[tasks.border]",
          "fg = \"" + c("outline_variant") + "\"",
          "",
          "[tasks.title]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[which.mask]",
          "bg = \"" + c("surface_container_low") + "\"",
          "",
          "[which.cand]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[which.rest]",
          "fg = \"" + c("on_surface_variant") + "\"",
          "",
          "[which.desc]",
          "fg = \"" + c("tertiary") + "\"",
          "",
          "[help.on]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[help.run]",
          "fg = \"" + c("tertiary") + "\"",
          "",
          "[help.desc]",
          "fg = \"" + c("on_surface") + "\"",
          "",
          "[help.hovered]",
          "fg = \"" + c("on_primary_container") + "\"",
          "bg = \"" + c("primary_container") + "\"",
          "bold = true",
          "",
          "[notify.title_info]",
          "fg = \"" + c("primary") + "\"",
          "",
          "[notify.title_warn]",
          "fg = \"" + c("tertiary") + "\"",
          "",
          "[notify.title_error]",
          "fg = \"" + c("error") + "\""
        ] | .[]
      ' colors.json > "$out/yazi/theme.toml"
    '';

  xdgPlaceholders = [
    { path = "yazi/theme.toml"; }
  ];

  links = [
    {
      name = "Yazi";
      target = ".config/yazi/theme.toml";
      source = "yazi/theme.toml";
    }
  ];
}
