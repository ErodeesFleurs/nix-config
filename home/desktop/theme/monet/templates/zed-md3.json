{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Monet MD3",
  "author": "matugen",
  "themes": [
    {
      "name": "@theme_name@",
      "appearance": "@appearance@",
      "style": {
        "border": "@outline_variant@ff",
        "border.variant": "@outline_variant@ff",
        "border.focused": "@primary@ff",
        "border.selected": "@primary@ff",
        "border.transparent": "#00000000",
        "border.disabled": "@outline_variant@80",
        "elevated_surface.background": "@surface_container_high@ff",
        "surface.background": "@surface_container@ff",
        "background": "@surface@ff",
        "element.background": "@surface_container_high@ff",
        "element.hover": "@surface_container_highest@ff",
        "element.active": "@primary_container@ff",
        "element.selected": "@primary_container@ff",
        "element.disabled": "@surface_container@99",
        "drop_target.background": "@primary@40",
        "ghost_element.background": "#00000000",
        "ghost_element.hover": "@primary@1f",
        "ghost_element.active": "@primary@2e",
        "ghost_element.selected": "@primary@2e",
        "ghost_element.disabled": "#00000000",
        "text": "@on_surface@ff",
        "text.muted": "@on_surface_variant@ff",
        "text.placeholder": "@on_surface_variant@bf",
        "text.disabled": "@on_surface_variant@80",
        "text.accent": "@primary@ff",
        "icon": "@on_surface@ff",
        "icon.muted": "@on_surface_variant@ff",
        "icon.disabled": "@on_surface_variant@80",
        "icon.placeholder": "@on_surface_variant@bf",
        "icon.accent": "@primary@ff",
        "status_bar.background": "@surface_container@ff",
        "title_bar.background": "@surface@ff",
        "title_bar.inactive_background": "@surface_container_low@ff",
        "toolbar.background": "@surface_container_low@ff",
        "tab_bar.background": "@surface_container@ff",
        "tab.inactive_background": "@surface_container@ff",
        "tab.active_background": "@surface@ff",
        "search.match_background": "@primary@33",
        "search.active_match_background": "@tertiary@4d",
        "panel.background": "@surface_container@ff",
        "panel.focused_border": "@primary@ff",
        "pane.focused_border": "@primary@ff",
        "scrollbar.thumb.background": "@on_surface_variant@4c",
        "scrollbar.thumb.hover_background": "@surface_container_highest@ff",
        "scrollbar.thumb.border": "@surface_container_highest@ff",
        "scrollbar.track.background": "#00000000",
        "scrollbar.track.border": "@surface_container@ff",
        "editor.foreground": "@on_surface@ff",
        "editor.background": "@surface@ff",
        "editor.gutter.background": "@surface@ff",
        "editor.subheader.background": "@surface_container@ff",
        "editor.active_line.background": "@surface_container@bf",
        "editor.highlighted_line.background": "@surface_container_low@ff",
        "editor.line_number": "@outline@ff",
        "editor.active_line_number": "@primary@ff",
        "editor.hover_line_number": "@on_surface_variant@ff",
        "editor.invisible": "@outline@99",
        "editor.wrap_guide": "@outline_variant@80",
        "editor.active_wrap_guide": "@outline_variant@ff",
        "editor.document_highlight.read_background": "@primary@1a",
        "editor.document_highlight.write_background": "@tertiary@26",
        "terminal.background": "@surface@ff",
        "terminal.foreground": "@on_surface@ff",
        "terminal.bright_foreground": "@on_surface@ff",
        "terminal.dim_foreground": "@on_surface_variant@ff",
        "terminal.ansi.black": "@surface_container_lowest@ff",
        "terminal.ansi.bright_black": "@outline@ff",
        "terminal.ansi.red": "@error@ff",
        "terminal.ansi.bright_red": "@error@ff",
        "terminal.ansi.green": "@secondary@ff",
        "terminal.ansi.bright_green": "@secondary@ff",
        "terminal.ansi.yellow": "@tertiary@ff",
        "terminal.ansi.bright_yellow": "@tertiary@ff",
        "terminal.ansi.blue": "@primary@ff",
        "terminal.ansi.bright_blue": "@primary@ff",
        "terminal.ansi.magenta": "@tertiary@ff",
        "terminal.ansi.bright_magenta": "@tertiary@ff",
        "terminal.ansi.cyan": "@secondary@ff",
        "terminal.ansi.bright_cyan": "@secondary@ff",
        "terminal.ansi.white": "@on_surface@ff",
        "terminal.ansi.bright_white": "@on_surface@ff",
        "link_text.hover": "@primary@ff",
        "version_control.added": "@secondary@ff",
        "version_control.modified": "@tertiary@ff",
        "version_control.deleted": "@error@ff",
        "created": "@secondary@ff",
        "created.background": "@secondary_container@4d",
        "deleted": "@error@ff",
        "deleted.background": "@error_container@4d",
        "error": "@error@ff",
        "error.background": "@error_container@4d",
        "hint": "@secondary@ff",
        "hint.background": "@secondary_container@4d",
        "info": "@primary@ff",
        "info.background": "@primary_container@4d",
        "modified": "@tertiary@ff",
        "modified.background": "@tertiary_container@4d",
        "success": "@secondary@ff",
        "success.background": "@secondary_container@4d",
        "warning": "@tertiary@ff",
        "warning.background": "@tertiary_container@4d",
        "players": [
          { "cursor": "@primary@ff", "background": "@primary@ff", "selection": "@primary@3d" },
          { "cursor": "@secondary@ff", "background": "@secondary@ff", "selection": "@secondary@3d" },
          { "cursor": "@tertiary@ff", "background": "@tertiary@ff", "selection": "@tertiary@3d" },
          { "cursor": "@error@ff", "background": "@error@ff", "selection": "@error@3d" }
        ],
        "syntax": {
          "attribute": { "color": "@tertiary@ff" },
          "boolean": { "color": "@tertiary@ff" },
          "comment": { "color": "@outline@ff", "font_style": "italic" },
          "constant": { "color": "@tertiary@ff" },
          "constructor": { "color": "@secondary@ff" },
          "function": { "color": "@primary@ff" },
          "keyword": { "color": "@primary@ff", "font_weight": 700 },
          "number": { "color": "@tertiary@ff" },
          "operator": { "color": "@tertiary@ff" },
          "property": { "color": "@secondary@ff" },
          "punctuation": { "color": "@on_surface_variant@ff" },
          "string": { "color": "@secondary@ff" },
          "type": { "color": "@secondary@ff" },
          "variable": { "color": "@on_surface@ff" }
        }
      }
    }
  ]
}
